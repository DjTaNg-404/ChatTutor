# ChatTutor Production Environment Configuration
# Copy this file to .env and update the values

# ===== API Keys =====
# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# OpenAI API Key (optional)
OPENAI_API_KEY=sk-your-openai-api-key

# Baidu Search API Key (optional)
BAIDU_API_KEY=your-baidu-api-key

# ===== Database Configuration =====
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://chattutor:your-password@localhost:5432/chattutor

# ===== Redis Configuration =====
# Redis connection string
# Format: redis://host:port/db
REDIS_URL=redis://localhost:6379/0

# ===== Kafka / Redpanda（可选）=====
# Docker 启用消息队列：docker compose -f docker/docker-compose.yml --profile kafka up -d
# 并将 KAFKA_ENABLED=true，KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=chattutor.events

# ===== Gunicorn 进程数（仅在使用 gunicorn 启动时）=====
GUNICORN_WORKERS=4

# ===== JWT Authentication =====
# IMPORTANT: Change this to a strong random string in production!
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-key-change-in-production

# Token expiration (minutes)
JWT_EXPIRE_MINUTES=1440

# ===== Langfuse Observability (optional) =====
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== Feature Flags =====
KG_ENABLED=false
ENABLE_STREAMING=true
ENABLE_PLAN_PROPOSAL=true

# ===== CORS Configuration =====
# Comma-separated list of allowed origins
FRONTEND_URL=http://localhost:3000

# ===== Model Configuration =====
MODEL_NAME=deepseek-chat
EVALUATOR_MODEL_NAME=deepseek-chat
